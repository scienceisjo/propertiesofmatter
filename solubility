      actions:[
        {label:'🟣 황산구리 실험 시작', style:'accent', onClick:()=>{closeModal();switchSolute('cuso4');}},
        {label:'잠시 확인할게요', onClick:closeModal}
      ]
    });
  }else if(state.solute==='cuso4' && remainCuso4.length===0){
    // 모두 완료
    document.getElementById('check-cuso4').style.display='inline';
    state.records.cuso4.na = 'NA';
    setTimeout(()=>{
      modal({
        icon:'🌟',
        title:'모든 실험을 완료했어요!',
        body:`두 물질의 모든 조건에 대한 포화 온도를 측정했습니다.<br><br>이제 그래프를 그려서 두 물질의 용해도가 어떻게 다른지 비교해 봅시다.`,
        actions:[
          {label:'📈 그래프 그리러 가기', style:'accent', onClick:()=>{closeModal();goStep('graph');}}
        ]
      });
    },300);
  }else{
    // 다음 조건 안내
    toast(`📍 ${soluteLabel} ${condLabel} = ${T}℃ 기록됨!`, true);
    // 자동으로 다음 조건으로 전환
    setTimeout(()=>{
      const nextConds = ['ga','na','da'].filter(c=>{
        if(state.solute==='cuso4' && c==='na') return false;
        return state.records[state.solute][c]===null;
      });
      if(nextConds.length>0){
        const next = nextConds[0];
        state.cond = next;
