}
function doRecord(){
  state.records[state.solute][state.cond] = state.temp;
  snd.record();
  updateRecordTable();
  syncCondPills();
  updateProgress();

  // 다음 단계 안내
  const remainKno3 = ['ga','na','da'].filter(c=>state.records.kno3[c]===null);
  const remainCuso4 = ['ga','da'].filter(c=>state.records.cuso4[c]===null);
  const T = state.temp.toFixed(1);
