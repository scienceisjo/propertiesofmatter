  }
};

document.querySelectorAll('.ac-options').forEach(group=>{
  group.addEventListener('change', e=>{
    if(e.target.type==='radio'){
      const q = group.dataset.q;
      state.analysisAnswers[q] = e.target.value;
      // 선택 시 옵션 강조
      group.querySelectorAll('.ac-option').forEach(o=>o.classList.remove('selected'));
      e.target.closest('.ac-option').classList.add('selected');
      snd.click();
    }
  });
});

function checkAllAnalysis(){
  const {q1,q2,q3} = state.analysisAnswers;
  if(!q1||!q2||!q3){
    toast('모든 질문에 답해 주세요');
    return;
  }
  let allCorrect=true;
  for(const q of ['q1','q2','q3']){
    const fb = document.getElementById('fb-'+q);
    const ans = state.analysisAnswers[q];
    if(ans===CORRECT[q]){
      fb.className='ac-feedback show correct';
      fb.textContent = FEEDBACK[q].correct;
    }else{
      fb.className='ac-feedback show wrong';
      fb.textContent = FEEDBACK[q].wrong;
      allCorrect=false;
    }
  }
  if(allCorrect){
    document.getElementById('final-card').style.display='block';
    setTimeout(()=>{
      document.getElementById('final-card').scrollIntoView({behavior:'smooth',block:'center'});
      celebrate();
    },300);
  }else{
    snd.error();
    toast('일부 답이 틀렸어요. 빨간 글자를 읽고 다시 시도해 보세요');
  }
}

