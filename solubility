/* ============================ GRAPH STAGE ============================ */
const GP = {PL:50, PR:24, PT:24, PB:42, maxT:100, maxS:260};
const cv = document.getElementById('graphCanvas');
const ctx = cv.getContext('2d');

function initGraphStage(){
  resizeCanvas();
  buildDpList();
  drawGraph();
}
function resizeCanvas(){
  if(state.step!=='graph') return;
  const wrap = cv.parentElement;
  const rect = wrap.getBoundingClientRect();
  const dpr = window.devicePixelRatio||1;
  cv.width = Math.floor(rect.width*dpr);
  cv.height = Math.floor(rect.height*dpr);
  cv.style.width = rect.width+'px';
  cv.style.height = rect.height+'px';
  ctx.setTransform(dpr,0,0,dpr,0,0);
  drawGraph();
}
window.addEventListener('resize',()=>{if(state.step==='graph')resizeCanvas();});

function gpos(t,s){
  const rect = cv.getBoundingClientRect();
  const W=rect.width, H=rect.height;
  const innerW = W-GP.PL-GP.PR, innerH=H-GP.PT-GP.PB;
  return {
    x: GP.PL + (t/GP.maxT)*innerW,
    y: (H-GP.PB) - (s/GP.maxS)*innerH
  };
}
function fromCanvasXY(x,y){
  const rect = cv.getBoundingClientRect();
  const W=rect.width, H=rect.height;
  const innerW = W-GP.PL-GP.PR, innerH=H-GP.PT-GP.PB;
  const t = (x-GP.PL)/innerW*GP.maxT;
  const s = ((H-GP.PB)-y)/innerH*GP.maxS;
  return {t,s};
}

function drawGraph(){
  const rect = cv.getBoundingClientRect();
  const W=rect.width, H=rect.height;
  ctx.clearRect(0,0,W,H);

  // grid
  ctx.strokeStyle='rgba(168,66,31,.15)';
  ctx.lineWidth=1;
  for(let t=0;t<=100;t+=10){
    const p=gpos(t,0);
    ctx.beginPath();ctx.moveTo(p.x,GP.PT);ctx.lineTo(p.x,H-GP.PB);ctx.stroke();
  }
  for(let s=0;s<=GP.maxS;s+=20){
    const p=gpos(0,s);
    ctx.beginPath();ctx.moveTo(GP.PL,p.y);ctx.lineTo(W-GP.PR,p.y);ctx.stroke();
  }

  // axes
  ctx.strokeStyle=getCSSVar('--ink');
  ctx.lineWidth=2;
  ctx.beginPath();
  ctx.moveTo(GP.PL,GP.PT);ctx.lineTo(GP.PL,H-GP.PB);ctx.lineTo(W-GP.PR,H-GP.PB);
  ctx.stroke();

  // axis labels
  ctx.fillStyle=getCSSVar('--ink');
  ctx.font='12px "Gowun Batang",serif';
  ctx.textAlign='center';
  for(let t=0;t<=100;t+=10){
    const p=gpos(t,0);
    ctx.fillText(t, p.x, H-GP.PB+16);
  }
  ctx.textAlign='right';
  for(let s=0;s<=GP.maxS;s+=20){
    const p=gpos(0,s);
    ctx.fillText(s, GP.PL-6, p.y+4);
  }
  ctx.textAlign='center';
  ctx.font='bold 13px "Gaegu",cursive';
  ctx.fillText('온도 (℃)', W/2, H-8);
  ctx.save();
  ctx.translate(14, H/2);
  ctx.rotate(-Math.PI/2);
  ctx.fillText('용해도 (g / 물 100g)', 0, 0);
  ctx.restore();

  // existing placed points
  // Group by solute
  for(const type of ['kno3','cuso4']){
    const pts = state.graphPoints.filter(p=>p.type===type).sort((a,b)=>a.t-b.t);
    if(pts.length===0) continue;
    // line through points
    ctx.strokeStyle = SOLUTE_COLOR[type];
    ctx.lineWidth=2.5;
    ctx.beginPath();
    pts.forEach((p,i)=>{
      const xy=gpos(p.t,p.sol);
      if(i===0)ctx.moveTo(xy.x,xy.y);else ctx.lineTo(xy.x,xy.y);
    });
    ctx.stroke();
    // dots
    pts.forEach(p=>{
      const xy=gpos(p.t,p.sol);
      ctx.beginPath();
      ctx.arc(xy.x,xy.y,5,0,Math.PI*2);
      ctx.fillStyle = SOLUTE_COLOR[type];
      ctx.fill();
      ctx.strokeStyle=getCSSVar('--paper');
      ctx.lineWidth=1.5;
      ctx.stroke();
    });
    // label on last point
    if(pts.length>=11){
      const last = pts[pts.length-1];
      const xy = gpos(last.t,last.sol);
      ctx.fillStyle = SOLUTE_COLOR[type];
      ctx.font='bold 12px "Gaegu",cursive';
      ctx.textAlign='right';
      ctx.fillText(SOLUTE_NAME[type], xy.x-8, xy.y-6);
    }
  }

  // hover preview
  if(_dragPreview){
    const xy=gpos(_dragPreview.t, _dragPreview.sol);
    ctx.beginPath();
    ctx.arc(xy.x,xy.y,8,0,Math.PI*2);
    ctx.fillStyle = SOLUTE_COLOR[_dragPreview.type];
    ctx.globalAlpha=.4;
    ctx.fill();
    ctx.globalAlpha=1;
    // crosshair
    ctx.strokeStyle = SOLUTE_COLOR[_dragPreview.type];
    ctx.setLineDash([4,3]);
    ctx.lineWidth=1.5;
    ctx.beginPath();
    ctx.moveTo(xy.x, H-GP.PB);ctx.lineTo(xy.x, xy.y);
    ctx.moveTo(GP.PL, xy.y);ctx.lineTo(xy.x, xy.y);
    ctx.stroke();
    ctx.setLineDash([]);
  }
}

function buildDpList(){
  const list = document.getElementById('dp-list');
  list.innerHTML='';
  const items = [];
  for(const type of ['kno3','cuso4']){
    if(state.dpFilter!=='all' && state.dpFilter!==type) continue;
    CURVES[type].forEach(([t,s])=>{
      items.push({type,t,sol:s});
    });
  }
  // shuffle for fun
  items.sort((a,b)=> (a.t*100+a.sol) - (b.t*100+b.sol));
  items.forEach(item=>{
    const placed = state.graphPoints.some(p=>p.type===item.type && p.t===item.t);
    const chip = document.createElement('div');
    chip.className='dp-chip'+(placed?' placed':'');
    chip.draggable=!placed;
    chip.dataset.solute=item.type;
    chip.dataset.t=item.t;
    chip.dataset.sol=item.sol;
    chip.innerHTML=`
      <span>${item.t}℃ → ${item.sol}g</span>
      <span class="dp-tag">${SOLUTE_NAME[item.type]}</span>
    `;
    if(!placed){
      chip.addEventListener('dragstart',onChipDragStart);
      chip.addEventListener('touchstart',onChipTouchStart,{passive:false});
    }
    list.appendChild(chip);
  });
}
function toggleDpFilter(){
  const order = ['all','kno3','cuso4'];
  const next = order[(order.indexOf(state.dpFilter)+1)%order.length];
  state.dpFilter = next;
  document.getElementById('dp-sw').textContent = next==='all'?'전체':SOLUTE_NAME[next]+'만';
  buildDpList();
}

/* === Drag and Drop === */
let _dragData=null;
let _dragPreview=null;

function onChipDragStart(e){
  _dragData = {
    type: e.currentTarget.dataset.solute,
    t: parseFloat(e.currentTarget.dataset.t),
    sol: parseFloat(e.currentTarget.dataset.sol)
  };
  e.dataTransfer.effectAllowed='copy';
  e.dataTransfer.setData('text/plain', JSON.stringify(_dragData));
}

cv.addEventListener('dragover', e=>{
  e.preventDefault();
  if(!_dragData) return;
  const rect = cv.getBoundingClientRect();
  const x=e.clientX-rect.left, y=e.clientY-rect.top;
  _dragPreview = {..._dragData}; // show actual data, not where mouse is
  // but show snapshot of where mouse hovers
  const m = fromCanvasXY(x,y);
  _dragPreview._mouse = m;
  drawGraph();
  // also show mouse hover dot
  const ctxxy = gpos(_dragData.t, _dragData.sol);
  // crosshair from mouse pos toward correct
  ctx.save();
  ctx.strokeStyle = getCSSVar('--ink-soft');
  ctx.setLineDash([2,3]);
  ctx.beginPath();
  ctx.arc(x,y,12,0,Math.PI*2);
  ctx.stroke();
  ctx.setLineDash([]);
  ctx.restore();
});
cv.addEventListener('dragleave', e=>{
  _dragPreview=null;
  drawGraph();
});
cv.addEventListener('drop', e=>{
  e.preventDefault();
  if(!_dragData) return;
  const rect = cv.getBoundingClientRect();
  const x = e.clientX-rect.left, y=e.clientY-rect.top;
  const m = fromCanvasXY(x,y);
  // 정확도 체크: 칩의 실제 좌표와 드롭 위치가 가까워야 함
  const target = gpos(_dragData.t, _dragData.sol);
  const dist = Math.hypot(target.x-x, target.y-y);
  if(dist > 38){
    toast('🎯 칩의 정확한 위치에 더 가깝게 떨어뜨려 주세요');
    _dragData=null; _dragPreview=null; drawGraph();
    return;
  }
  placePoint(_dragData);
  _dragData=null; _dragPreview=null;
});
// Touch DnD
let _touchChipData=null, _touchGhost=null;
function onChipTouchStart(e){
  e.preventDefault();
  _touchChipData = {
    type: e.currentTarget.dataset.solute,
    t: parseFloat(e.currentTarget.dataset.t),
    sol: parseFloat(e.currentTarget.dataset.sol)
  };
  const t = e.touches[0];
  _touchGhost = document.createElement('div');
  _touchGhost.style.cssText = `
    position:fixed;z-index:9999;pointer-events:none;
    padding:5px 10px;background:${SOLUTE_COLOR[_touchChipData.type]};color:#fff;
    font-family:'Gaegu',cursive;font-weight:700;font-size:12px;
    border:1.5px solid var(--ink);box-shadow:3px 3px 0 var(--ink);
    transform:translate(-50%,-50%);
  `;
  _touchGhost.textContent = `${_touchChipData.t}℃→${_touchChipData.sol}g`;
  document.body.appendChild(_touchGhost);
  moveTouchGhost(t);
}
function moveTouchGhost(t){
  if(!_touchGhost) return;
  _touchGhost.style.left=t.clientX+'px';
  _touchGhost.style.top=(t.clientY-24)+'px';
}
document.addEventListener('touchmove', e=>{
  if(!_touchChipData) return;
  e.preventDefault();
  const t = e.touches[0];
  moveTouchGhost(t);
  const rect = cv.getBoundingClientRect();
  if(t.clientX>=rect.left && t.clientX<=rect.right && t.clientY>=rect.top && t.clientY<=rect.bottom){
    _dragPreview = {..._touchChipData};
    drawGraph();
    // crosshair from touch
    const x=t.clientX-rect.left, y=t.clientY-rect.top;
    ctx.save();
    ctx.strokeStyle = getCSSVar('--ink-soft');
    ctx.setLineDash([2,3]);
    ctx.beginPath();
    ctx.arc(x,y,16,0,Math.PI*2);
    ctx.stroke();
    ctx.setLineDash([]);
    ctx.restore();
  }
},{passive:false});
document.addEventListener('touchend', e=>{
  if(!_touchChipData) return;
  if(_touchGhost){_touchGhost.remove();_touchGhost=null;}
  const t = e.changedTouches[0];
  const rect = cv.getBoundingClientRect();
  if(t.clientX>=rect.left && t.clientX<=rect.right && t.clientY>=rect.top && t.clientY<=rect.bottom){
    const x=t.clientX-rect.left, y=t.clientY-rect.top;
    const target = gpos(_touchChipData.t, _touchChipData.sol);
    const dist = Math.hypot(target.x-x, target.y-y);
    if(dist>50){
      toast('🎯 칩의 정확한 위치에 더 가깝게 떨어뜨려 주세요');
    }else{
      placePoint(_touchChipData);
    }
  }
  _touchChipData=null; _dragPreview=null; drawGraph();
});

function placePoint(data){
  state.graphPoints.push({...data, placed:true});
  snd.drop();
  drawGraph();
  buildDpList();
  // toast
  toast(`✓ (${data.t}℃, ${data.sol}g) 점을 찍었어요`, true);

  // 완성 체크
  if(state.graphPoints.length===22){
    setTimeout(()=>{
      document.getElementById('btn-to-analysis').disabled=false;
      document.getElementById('btn-to-analysis').classList.add('moss');
      modal({
        icon:'📈',
        title:'용해도 곡선 완성!',
        body:`두 물질의 <b>온도-용해도 곡선</b>을 완성했어요.<br><br>
          이제 두 곡선을 비교해서 <b>"용해도가 물질의 특성"</b>임을 확인해 봅시다.`,
        actions:[
          {label:'🔍 결론 분석하기', style:'accent', onClick:()=>{closeModal();goStep('analysis');}},
          {label:'그래프 더 볼게요', onClick:closeModal}
        ]
      });
    },400);
  }
}
function clearGraph(){
  if(state.graphPoints.length===0){toast('찍은 점이 없어요');return}
  modal({
    icon:'↺',
    title:'그래프를 모두 지울까요?',
    body:'찍은 점이 모두 사라지고 데이터 칩이 다시 활성화됩니다.',
    actions:[
      {label:'네, 지울게요', style:'accent', onClick:()=>{
        closeModal();
        state.graphPoints=[];
        document.getElementById('btn-to-analysis').disabled=true;
        document.getElementById('btn-to-analysis').classList.remove('moss');
        buildDpList();
        drawGraph();
      }},
      {label:'취소', onClick:closeModal}
    ]
  });
}

