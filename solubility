<script>
/* ============================ DATA ============================ */
// 용해도 곡선 데이터 (g / 물100g)
const CURVES = {
  kno3:  [[0,13.3],[10,21],[20,31.6],[30,45.8],[40,63.9],[50,84.5],[60,109],[70,138],[80,169],[90,202],[100,246]],
  cuso4: [[0,14.0],[10,17.0],[20,20.7],[30,25.0],[40,28.5],[50,33.3],[60,40.0],[70,47.0],[80,55.0],[90,64.0],[100,75.4]]
};
const SOLUTE_NAME = {kno3:'질산칼륨', cuso4:'황산구리'};
const SOLUTE_COLOR = {kno3:getCSSVar('--kno3'), cuso4:getCSSVar('--cuso4')};
function getCSSVar(name){return getComputedStyle(document.documentElement).getPropertyValue(name).trim()}

// 조건: 물질량(g), 용질량(g), 용질이 녹기 시작하는 농도 = 용질/물*100
const CONDS = {
  ga: {water:100, solute:50,  label:'(가)'},  // 50 g/100g 물
  na: {water:100, solute:100, label:'(나)'},  // 100 g/100g 물
  da: {water:200, solute:100, label:'(다)'}   // 50 g/100g 물
};

// 각 조건에서 석출 시작 온도 (curves에서 해당 농도 만나는 온도 역추정)
function solubilityAtT(type, t){
  const d = CURVES[type];
  if(t<=d[0][0]) return d[0][1];
  if(t>=d[d.length-1][0]) return d[d.length-1][1];
  for(let i=0;i<d.length-1;i++){
    if(t>=d[i][0] && t<=d[i+1][0]){
      const r = (t-d[i][0])/(d[i+1][0]-d[i][0]);
      return d[i][1] + r*(d[i+1][1]-d[i][1]);
    }
  }
  return d[d.length-1][1];
}
function precipTemp(type, conc){
  // conc = g per 100g water. 온도를 0→100 훑으며 solubility==conc 인 지점
  const d = CURVES[type];
  if(conc > d[d.length-1][1]) return null; // 100℃에서도 안녹음
  if(conc <= d[0][1]) return 0;
  for(let i=0;i<d.length-1;i++){
    if(conc>=d[i][1] && conc<=d[i+1][1]){
      const r = (conc-d[i][1])/(d[i+1][1]-d[i][1]);
      return d[i][0] + r*(d[i+1][0]-d[i][0]);
    }
  }
  return null;
}

// 정답 온도 사전 계산
const CORRECT_TEMPS = {};
for(const type of ['kno3','cuso4']){
  CORRECT_TEMPS[type] = {};
  for(const ck of ['ga','na','da']){
    const c = CONDS[ck];
    const conc = c.solute/c.water*100;
    CORRECT_TEMPS[type][ck] = precipTemp(type, conc);
  }
}
// cuso4-na 는 null (100도 초과)

/* ============================ STATE ============================ */
const state = {
  step:'intro',
  solute:'kno3',
  cond:'ga',
  temp:100,
  prepared:false,
  precipStarted:false,
  precipPopupShown:false,
  records:{ // 기록된 온도
    kno3:{ga:null,na:null,da:null},
    cuso4:{ga:null,na:null,da:null}
  },
  graphPoints:[], // {type, t, sol, placed:true}
  dpFilter:'all', // all|kno3|cuso4
  analysisAnswers:{q1:null,q2:null,q3:null}
};

/* ============================ AUDIO ============================ */
let _ac=null;
function getAC(){
  if(!_ac){try{_ac=new(window.AudioContext||window.webkitAudioContext)();}catch(e){}}
  if(_ac && _ac.state==='suspended') _ac.resume();
  return _ac;
}
function tone(f,d,t='sine',v=.22){
  const ac=getAC();if(!ac)return;
  try{
    const o=ac.createOscillator(),g=ac.createGain();
    o.type=t;o.frequency.value=f;
    g.gain.setValueAtTime(v,ac.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001,ac.currentTime+d);
    o.connect(g);g.connect(ac.destination);o.start();o.stop(ac.currentTime+d);
  }catch(e){}
}
function noise(d,lp,v=.2){
  const ac=getAC();if(!ac)return;
  try{
    const buf=ac.createBuffer(1,Math.floor(ac.sampleRate*d),ac.sampleRate);
    const a=buf.getChannelData(0);
    for(let i=0;i<a.length;i++)a[i]=(Math.random()*2-1)*Math.exp(-i/(ac.sampleRate*d*.6));
    const s=ac.createBufferSource();s.buffer=buf;
    const f=ac.createBiquadFilter();f.type='lowpass';f.frequency.value=lp;
    const g=ac.createGain();g.gain.setValueAtTime(v,ac.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001,ac.currentTime+d);
    s.connect(f);f.connect(g);g.connect(ac.destination);s.start();
  }catch(e){}
}
const snd = {
  splash:()=>noise(.22,900,.22),
  pour:()=>noise(.15,2500,.18),
  click:()=>tone(660,.06,'sine',.12),
  record:()=>{tone(880,.08,'sine',.18);setTimeout(()=>tone(1320,.08,'sine',.15),60)},
  success:()=>{[523,659,784,1047].forEach((f,i)=>setTimeout(()=>tone(f,.22,'sine',.2),i*110))},
  error:()=>{tone(280,.12,'sawtooth',.16);setTimeout(()=>tone(200,.1,'sawtooth',.12),100)},
  alert:()=>{tone(880,.12,'sine',.22);setTimeout(()=>tone(660,.18,'sine',.18),120)},
  drop:()=>tone(440,.08,'sine',.12)
};

/* ============================ TOAST / MODAL ============================ */
function toast(msg, ok=false){
  const el=document.getElementById('toast');
  el.textContent=msg;el.className=ok?'toast show ok':'toast show';
  clearTimeout(el._t);el._t=setTimeout(()=>el.classList.remove('show'),2600);
  if(!ok) snd.error();
}
function modal(opts){
  const m=document.getElementById('modal');
  document.getElementById('modal-icon').textContent=opts.icon||'📝';
  document.getElementById('modal-title').textContent=opts.title||'알림';
  document.getElementById('modal-body').innerHTML=opts.body||'';
  const ac=document.getElementById('modal-actions');
  ac.innerHTML='';
  (opts.actions||[{label:'확인', onClick:closeModal}]).forEach(a=>{
    const b=document.createElement('button');
    b.className='big-btn '+(a.style||'');
    b.textContent=a.label;
    b.onclick=a.onClick;
    ac.appendChild(b);
  });
  m.classList.add('show');
}
function closeModal(){document.getElementById('modal').classList.remove('show')}
document.getElementById('modal').addEventListener('click',e=>{
  if(e.target.id==='modal') closeModal();
});

function celebrate(){
  snd.success();
  const colors=[getCSSVar('--rust'),getCSSVar('--mustard'),getCSSVar('--moss'),getCSSVar('--accent'),getCSSVar('--plum')];
  for(let i=0;i<80;i++){
    setTimeout(()=>{
      const el=document.createElement('div');
      const sz=Math.random()*10+5;
      el.style.cssText=`position:fixed;left:${Math.random()*100}vw;top:-20px;width:${sz}px;height:${sz}px;background:${colors[Math.floor(Math.random()*colors.length)]};border-radius:${Math.random()>.5?'50%':'2px'};animation:confetti-fall ${Math.random()*1.8+1.2}s forwards;z-index:9998;pointer-events:none;`;
      document.body.appendChild(el);setTimeout(()=>el.remove(),3500);
    },i*22);
  }
}

/* ============================ STEPPER ============================ */
function goStep(stepName){
  // Guardrails
  if(stepName==='graph'){
    const total = countRecorded();
    if(total<5){
      modal({
        icon:'📋',
        title:'아직 측정이 끝나지 않았어요',
        body:`먼저 모든 조건을 측정해 주세요.<br><br><b>현재 진행도: ${total}/5</b><br><span style="font-size:13px;color:var(--ink-faded)">(황산구리 (나) 조건은 측정 불가입니다)</span>`,
      });
      return;
    }
  }
  if(stepName==='analysis'){
    if(state.graphPoints.length<22){ // kno3 11점 + cuso4 11점
      modal({
        icon:'📈',
        title:'그래프를 더 그려보세요',
        body:`아직 모든 점을 찍지 않았어요.<br><b>${state.graphPoints.length} / 22</b> 점을 찍어야 곡선이 완성됩니다.`,
      });
      return;
    }
  }

  state.step = stepName;
  document.querySelectorAll('.stage').forEach(s=>s.classList.remove('on'));
  document.getElementById('stage-'+stepName).classList.add('on');

  // Update stepper
  const steps = ['intro','exp','graph','analysis'];
  const idx = steps.indexOf(stepName);
  document.querySelectorAll('.step').forEach(el=>{
    const s = el.dataset.step;
    const si = steps.indexOf(s);
    el.classList.remove('active','done');
    if(si<idx) el.classList.add('done');
    else if(si===idx) el.classList.add('active');
  });
  snd.click();

  // Step-specific init
  if(stepName==='graph'){
    initGraphStage();
  }
  if(stepName==='analysis'){
    // nothing initial
  }
  window.scrollTo({top:0,behavior:'smooth'});
}

/* ============================ EXPERIMENT STAGE ============================ */
function switchSolute(type){
  if(type===state.solute) return;
  state.solute=type;
  document.querySelectorAll('.solute-tab').forEach(t=>t.classList.toggle('on', t.dataset.solute===type));
  // 황산구리로 전환했고 (나) 였다면 다른 조건으로
  if(type==='cuso4' && state.cond==='na'){
    state.cond='ga';
  }
  resetBeakerSilent();
  syncCondPills();
  syncTag();
  snd.click();
  // 알림: 첫 전환 시
  if(type==='cuso4' && !state._cuso4Notified){
    state._cuso4Notified=true;
    modal({
      icon:'🟣',
      title:'황산구리 실험으로 전환했어요',
      body:'이제 <b>황산구리(CuSO₄)</b>로 동일한 방식으로 실험을 진행하세요.<br><br>※ (나) 조건은 100℃를 초과해서 측정 불가입니다. 자동으로 표에 처리되어 있어요.'
    });
  }
}
function switchCond(c){
  if(c===state.cond) return;
  if(state.solute==='cuso4' && c==='na'){
    toast('황산구리 (나) 조건은 측정 불가입니다');
    return;
  }
  state.cond=c;
  syncCondPills();
  resetBeakerSilent();
  syncTag();
  snd.click();
}
function syncCondPills(){
  document.querySelectorAll('.cond-pill').forEach(p=>{
    const c=p.dataset.cond;
    p.classList.toggle('on', c===state.cond);
    const isRecorded = state.records[state.solute][c]!==null;
    p.classList.toggle('recorded', isRecorded);
    // 황산구리 (나) 비활성
    if(state.solute==='cuso4' && c==='na'){
      p.style.opacity='.4';
      p.style.cursor='not-allowed';
    }else{
      p.style.opacity='';
      p.style.cursor='';
    }
  });
}
function syncTag(){
  document.getElementById('exp-tag').textContent =
    (state.solute==='kno3'?'KNO3':'CuSO4') + ' · ' + CONDS[state.cond].label.replace(/[()]/g,'').toUpperCase();
}

function prepareBeaker(){
  const c = CONDS[state.cond];
  state.prepared=true;
  state.precipStarted=false;
  state.precipPopupShown=false;
  state.temp=100;
  document.getElementById('temp-slider').value=100;
  snd.splash();
  setTimeout(()=>{snd.pour();playSpoon();}, 400);
  updateAll();
  toast(`✅ ${CONDS[state.cond].label} 조건 준비 완료! 이제 온도를 천천히 낮추세요`, true);
}
function resetBeaker(){
  if(!state.prepared){toast('이미 비어있는 비커입니다');return}
  resetBeakerSilent();
  toast('🔄 비커 초기화됨', true);
}
function resetBeakerSilent(){
  state.prepared=false;
  state.precipStarted=false;
  state.precipPopupShown=false;
  state.temp=100;
  document.getElementById('temp-slider').value=100;
  updateAll();
}

function playSpoon(){
  const bench = document.getElementById('bench-area');
  const color = state.solute==='kno3' ? '#d8d4c4' : '#6b3a5c';
  const spoon = document.createElement('div');
  spoon.className='spoon-anim';
  bench.appendChild(spoon);
  for(let i=0;i<14;i++){
    const p=document.createElement('div');
    p.className='pwdr-particle';
    p.style.background=color;
    const sz = 5 + Math.random()*4;
    p.style.width=sz+'px';p.style.height=sz+'px';
    p.style.left = (bench.offsetWidth/2 + 8 + Math.random()*20) + 'px';
    p.style.top = '74px';
    p.style.setProperty('--dx', (Math.random()*20-10)+'px');
    p.style.setProperty('--dy', (60+Math.random()*50)+'px');
    p.style.animationDelay = (.3+Math.random()*.3)+'s';
    p.style.animationDuration = (.5+Math.random()*.3)+'s';
    bench.appendChild(p);
    setTimeout(()=>p.remove(),1400);
  }
  setTimeout(()=>spoon.remove(),1500);
}

function changeTemp(delta){
  if(!state.prepared){
    toast('먼저 비커에 물과 용질을 넣어주세요');
    return;
  }
  const s = document.getElementById('temp-slider');
  let v = parseFloat(s.value)+delta;
  if(v<0)v=0;if(v>100)v=100;
  s.value=v;
  state.temp=v;
  updateAll();
}
document.getElementById('temp-slider').addEventListener('input',e=>{
  if(!state.prepared){
    toast('먼저 비커에 물과 용질을 넣어주세요');
    e.target.value = state.temp;
    return;
  }
  state.temp = parseFloat(e.target.value);
  updateAll();
});

function getPrecipAmount(){
  if(!state.prepared) return 0;
  const c = CONDS[state.cond];
  const maxSoluteG = solubilityAtT(state.solute, state.temp) * c.water/100;
  return Math.max(0, c.solute - maxSoluteG);
}

function updateAll(){
  const c = CONDS[state.cond];
  // Temp display
  document.getElementById('temp-display').textContent = state.temp.toFixed(1);
  document.getElementById('mbl-temp').textContent = state.temp.toFixed(1)+'℃';
  // Hot plate color
  const hp = document.getElementById('hp-top');
  if(state.temp>50){
    const r=Math.floor(91+(state.temp-50)/50*120);
    hp.style.background = `rgb(${r},${Math.max(40,80-state.temp/3)|0},${Math.max(20,60-state.temp/2)|0})`;
    hp.style.boxShadow = state.temp>70?`0 0 ${(state.temp-70)*0.6}px rgba(200,80,20,.6)`:'';
  }else{
    const b=Math.floor(120+(50-state.temp)/50*80);
    hp.style.background = `rgb(${Math.max(60,91-state.temp)|0},${100|0},${b})`;
    hp.style.boxShadow='';
  }
  // Water fill class
  const wf = document.getElementById('water-fill');
  wf.classList.remove('warm','cold');
  if(state.temp>60) wf.classList.add('warm');
  else if(state.temp<25) wf.classList.add('cold');

  // Water height
  if(state.prepared){
    const pct = c.water/200*70; // 200g=70% fill
    wf.style.height = pct+'%';
  }else{
    wf.style.height='0%';
  }
  // Precip
  const pr = getPrecipAmount();
  const pf = document.getElementById('precip-fill');
  pf.className='precip-fill '+(state.prepared?state.solute:'');
  if(state.prepared && pr>0){
    pf.style.height = Math.min(30, pr/100*30) + '%';
  }else{
    pf.style.height='0%';
  }

  // Status
  document.getElementById('sr-water').textContent = state.prepared ? c.water+' g' : '— g';
  document.getElementById('sr-solute').textContent = state.prepared ? c.solute+' g ('+SOLUTE_NAME[state.solute]+')' : '— g';
  document.getElementById('sr-temp').textContent = state.temp.toFixed(1)+' ℃';
  document.getElementById('sr-precip').textContent = state.prepared ? pr.toFixed(1)+' g' : '0.0 g';

  // Precip row pulse
  const precipRow = document.getElementById('sr-precip-row');
  precipRow.classList.toggle('active', pr>0.1);

  // Trigger precip popup
  if(state.prepared && pr>0.1 && !state.precipPopupShown){
    triggerPrecipPopup();
  }
  if(state.prepared && pr<=0.05){
    state.precipPopupShown=false; // reset if re-melted
  }
}

